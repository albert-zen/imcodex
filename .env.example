# Core runtime
IMCODEX_DATA_DIR=.imcodex
# Codex executable used by both the bridge and `python -m imcodex app-server ...`.
# Requires codex-cli 0.120.0 or newer for current native thread discovery compatibility.
IMCODEX_CODEX_BIN=codex
# App Server target. unix:// selects Codex's default local control socket and is
# the normal macOS/Linux path. TCP WebSocket remains an explicit compatibility
# option; stdio:// explicitly selects the bridge-child compatibility runtime.
# Connection failure never changes this target or falls back to another server.
# When no target is configured, scripts/start.sh ensures the native daemon and
# selects unix://; scripts/start.ps1 selects stdio:// on native Windows.
# Setting this explicitly is connect-only: launchers will not start a server.
# IMCODEX_APP_SERVER_URL=unix://
# IMCODEX_APP_SERVER_URL=ws://127.0.0.1:8765
# IMCODEX_APP_SERVER_URL=stdio://
# Experimental native app-server capabilities are opt-in; keep disabled unless testing gated protocol features.
IMCODEX_APP_SERVER_EXPERIMENTAL_API=0
# Optional websocket Authorization header. Prefer the token file for local secrets.
# IMCODEX_APP_SERVER_AUTH_TOKEN_FILE=.imcodex-appserver-token
# IMCODEX_APP_SERVER_AUTH_TOKEN=
# Websocket connection and native overload retry bounds.
IMCODEX_APP_SERVER_CONNECT_MAX_ATTEMPTS=3
IMCODEX_APP_SERVER_REQUEST_MAX_ATTEMPTS=3
IMCODEX_APP_SERVER_RETRY_INITIAL_DELAY=0.25
IMCODEX_APP_SERVER_RETRY_MAX_DELAY=2.0
IMCODEX_APP_SERVER_RETRY_JITTER=0.25
IMCODEX_APP_SERVER_CONNECT_TIMEOUT=3.0
IMCODEX_APP_SERVER_HEALTH_TIMEOUT=1.0
# After an established external App Server disconnects, retry forever in the
# background with a separately capped backoff. Initial startup remains
# bounded by IMCODEX_APP_SERVER_CONNECT_MAX_ATTEMPTS.
IMCODEX_APP_SERVER_RECONNECT_INITIAL_DELAY=0.5
IMCODEX_APP_SERVER_RECONNECT_MAX_DELAY=30.0
IMCODEX_APP_SERVER_RECONNECT_JITTER=0.25
IMCODEX_LOG_LEVEL=INFO
IMCODEX_HTTP_HOST=0.0.0.0
IMCODEX_HTTP_PORT=8000
IMCODEX_SERVICE_NAME=imcodex

# Required for asynchronous results when using the generic inbound webhook.
# IMCODEX_OUTBOUND_URL=https://your-adapter.example/api/outbound
# Remote receivers must verify this Bearer token.
# IMCODEX_OUTBOUND_WEBHOOK_TOKEN=
# Remote callers of the generic inbound webhook must send this as a Bearer token.
# Without a token, that endpoint accepts loopback clients only.
# IMCODEX_INBOUND_WEBHOOK_TOKEN=

# QQ channel
IMCODEX_QQ_ENABLED=0
IMCODEX_QQ_APP_ID=
IMCODEX_QQ_CLIENT_SECRET=
IMCODEX_QQ_API_BASE=https://api.sgroup.qq.com
# For QQ sandbox testing only:
# IMCODEX_QQ_API_BASE=https://sandbox.api.sgroup.qq.com
IMCODEX_QQ_MARKDOWN_ENABLED=1
# Empty means deny all inbound users. Use stable platform openids; use * only deliberately.
IMCODEX_QQ_ALLOWED_USER_IDS=
# Optional comma-separated internal conversation ids such as c2c:<openid> or group:<openid>.
IMCODEX_QQ_ALLOWED_CONVERSATION_IDS=

# Telegram channel (Bot API long polling; no public callback URL required)
IMCODEX_TELEGRAM_ENABLED=0
# Prefer the token file over a direct environment value (chmod 600 on POSIX).
# IMCODEX_TELEGRAM_BOT_TOKEN_FILE=.telegram-bot-token
IMCODEX_TELEGRAM_BOT_TOKEN=
IMCODEX_TELEGRAM_API_BASE=https://api.telegram.org
# Comma-separated numeric Telegram user IDs. Empty means deny all.
IMCODEX_TELEGRAM_ALLOWED_USER_IDS=
# Optional internal ids such as chat:123, chat:-100123, or chat:-100123:topic:77.
IMCODEX_TELEGRAM_ALLOWED_CONVERSATION_IDS=
IMCODEX_TELEGRAM_REQUIRE_MENTION=1
IMCODEX_TELEGRAM_POLL_TIMEOUT=30

# Feishu / Lark channel (official websocket Channel SDK; install .[feishu])
IMCODEX_FEISHU_ENABLED=0
IMCODEX_FEISHU_APP_ID=
IMCODEX_FEISHU_APP_SECRET=
# feishu for China, lark for the international service.
IMCODEX_FEISHU_DOMAIN=feishu
# Comma-separated sender open_ids. Empty means deny all.
IMCODEX_FEISHU_ALLOWED_USER_IDS=
# Optional internal ids such as chat:oc_xxx or chat:oc_xxx:thread:omt_xxx.
IMCODEX_FEISHU_ALLOWED_CONVERSATION_IDS=
IMCODEX_FEISHU_REQUIRE_MENTION=1
IMCODEX_FEISHU_STARTUP_TIMEOUT=30

# Personal Weixin via Tencent iLink (experimental, direct text only)
# First run: python -m imcodex channels login weixin
IMCODEX_WEIXIN_ENABLED=0
# Defaults to IMCODEX_DATA_DIR/channels/weixin.
# IMCODEX_WEIXIN_STATE_DIR=.imcodex/channels/weixin
# QR login restricts access to the scanning owner only while this explicit list is empty.
# When set, this list replaces that default, so include the owner if they should remain admitted.
IMCODEX_WEIXIN_ALLOWED_USER_IDS=
IMCODEX_WEIXIN_ALLOWED_CONVERSATION_IDS=
IMCODEX_WEIXIN_POLL_TIMEOUT_MS=35000
