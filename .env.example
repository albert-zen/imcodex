# Core runtime
IMCODEX_DATA_DIR=.imcodex-data
IMCODEX_CODEX_BIN=codex
IMCODEX_LOG_LEVEL=INFO
IMCODEX_HTTP_HOST=0.0.0.0
IMCODEX_HTTP_PORT=8000
IMCODEX_APP_SERVER_HOST=127.0.0.1
IMCODEX_APP_SERVER_PORT=8765
IMCODEX_SERVICE_NAME=imcodex

# Optional outbound webhook
# IMCODEX_OUTBOUND_URL=https://your-adapter.example/api/outbound

# Native permission profile
# review       -> follow native Codex defaults
# autonomous   -> override to approval_policy=never while keeping native sandbox defaults
IMCODEX_DEFAULT_PERMISSION_PROFILE=autonomous

# QQ channel
IMCODEX_QQ_ENABLED=0
IMCODEX_QQ_APP_ID=
IMCODEX_QQ_CLIENT_SECRET=
IMCODEX_QQ_API_BASE=https://sandbox.api.sgroup.qq.com
