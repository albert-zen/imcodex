{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/agentkit codex-stop-hook --log \".agentkit/codex-stop-hook.log\"",
            "commandWindows": "scripts\\agentkit.cmd codex-stop-hook --log \".agentkit\\codex-stop-hook.log\"",
            "timeout": 30,
            "statusMessage": "Checking AgentKit task closeout"
          }
        ]
      }
    ]
  }
}
